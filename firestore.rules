rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (default-deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isVerifiedAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'kkgjatinagaraciamis@gmail.com';
    }

    function isValidMenu(menu) {
      return menu.keys().hasAll(['id', 'title', 'icon', 'content', 'reloadUrl', 'isActive', 'order']) &&
             menu.keys().size() == 7 &&
             menu.id is string && menu.id.size() <= 128 &&
             menu.title is string && menu.title.size() <= 200 &&
             menu.icon is string && menu.icon.size() <= 100 &&
             menu.content is string && menu.content.size() <= 50000 &&
             menu.reloadUrl is string && menu.reloadUrl.size() <= 1000 &&
             menu.isActive is bool &&
             (menu.order is int || menu.order is float || menu.order is number);
    }

    // 2. Menus Collection
    match /menus/{menuId} {
      allow read: if true; // Public access for reading madrasah materials
      
      allow create: if isValidId(menuId) && 
                    isValidMenu(request.resource.data) && 
                    request.resource.data.id == menuId;
                    
      allow update: if isValidId(menuId) && 
                    isValidMenu(request.resource.data) &&
                    request.resource.data.id == resource.data.id;
                    
      allow delete: if isValidId(menuId);
    }
  }
}
